# Telegram bot token from BotFather (KEEP SECRET — never commit the real one)
BOT_TOKEN=123456:replace-me
# Bot username without @ (used to strip the mention from guest messages)
BOT_USERNAME=your_bot_username
# Groq API key from https://console.groq.com (free tier)
GROQ_API_KEY=gsk_replace-me
# Public domain whose A-record points at this VPS (used for HTTPS + webhook URL)
WEBHOOK_DOMAIN=bot.example.com
# Random string Telegram echoes back in the X-Telegram-Bot-Api-Secret-Token header
WEBHOOK_SECRET=change-me-to-a-long-random-string
# Optional overrides
GROQ_MODEL=llama-3.3-70b-versatile
# OpenAI-compatible chat-completions endpoint. Defaults to Groq; point it at any
# OpenAI-compatible backend, e.g. a self-hosted llama.cpp server:
#   AI_BASE_URL=http://your-host:8080/v1/chat/completions
# When using a backend that ignores auth, GROQ_API_KEY can be any non-empty string.
AI_BASE_URL=https://api.groq.com/openai/v1/chat/completions
CONTEXT_MESSAGES=10
DB_PATH=/data/memory.db
PORT=8080
# System prompt that defines the assistant's persona/behavior.
# Leave unset for a generic default; customize to give your bot its own personality.
SYSTEM_PROMPT=You are a helpful AI assistant in Telegram. Answer the user's message directly and concisely.
# Secretary (Business) Mode persona. The bot replies AS the account owner, in the
# first person, to incoming private messages in chats connected via Telegram Business.
# Leave unset for a conservative default that won't make commitments on your behalf.
BUSINESS_SYSTEM_PROMPT=You are replying on behalf of the account owner, in the first person, as if you were them. Be polite, concise, and natural. Do NOT agree to payments, make firm commitments, schedule meetings, or make promises on the owner's behalf.
